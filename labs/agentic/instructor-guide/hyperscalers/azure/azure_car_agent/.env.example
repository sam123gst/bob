# --- Required: Azure AI Foundry ---
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com
FOUNDRY_MODEL=gpt-4o-mini

# --- Server ---
HOST=0.0.0.0
PORT=10000
# Public URL for the agent card when deployed (overrides HOST/PORT in the card)
# HOST_OVERRIDE=https://car-agent.<region>.azurecontainerapps.io

# --- Agent ---
AGENT_NAME=car_review_agent
AGENT_DESCRIPTION=Helps with car reviews
AGENT_VERSION=1.0.0
AGENT_STREAMING=true
WEB_SEARCH_CONTEXT_SIZE=high
SUPPORTED_CONTENT_TYPES=text,text/plain

# Optional: override the default system prompt (use \n for line breaks)
# AGENT_INSTRUCTIONS=You are a car review agent...

# --- A2A agent card skill ---
SKILL_ID=create_car_review
SKILL_NAME=Car Review Tool
SKILL_DESCRIPTION=Helps with creating car reviews
SKILL_TAGS=car reviews|car review creation
SKILL_EXAMPLES=What are the reviews for the 1 SUV Adventure in Metallic Black with the safety package

# --- A2A protocol ---
A2A_PROTOCOL_BINDING=JSONRPC
